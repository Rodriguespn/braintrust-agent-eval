{
  "name": "@supabase/agent-evals",
  "version": "0.9.2",
  "description": "Framework for testing AI coding agents in isolated sandboxes",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/supabase/agent-evals.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:docker": "SANDBOX_BACKEND=docker vitest run src/lib/docker-sandbox.test.ts",
    "test:integration": "INTEGRATION_TEST=1 vitest run src/integration.test.ts",
    "test:integration:docker": "SANDBOX_BACKEND=docker INTEGRATION_TEST=1 vitest run src/integration.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "ai": "^5.0.11",
    "braintrust": "^3.2.0",
    "chalk": "^5.3.0",
    "dockerode": "^4.0.9",
    "dotenv": "^16.4.5",
    "glob": "^11.0.0",
    "jiti": "^2.6.1",
    "minimatch": "^10.1.2",
    "p-limit": "^6.1.0",
    "tar-stream": "^3.1.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.0.0",
    "@types/tar-stream": "^3.1.4",
    "eslint": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ai",
    "eval",
    "testing",
    "claude",
    "agent",
    "sandbox"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
